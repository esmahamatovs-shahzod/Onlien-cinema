// Хранилище сессий пользователей
const userSessions = new Map();

// Главное меню
function getMainMenuKeyboard() {
  return Markup.keyboard([
    ['🚀 Начать викторину'],
    ['📊 Мой счет', '🔄 Сбросить прогресс']
  ]).resize();
}

// Отправка вопроса с инлайн-кнопками вариантов ответа
async function sendQuestion(ctx, questionIndex) {
  const q = quizQuestions[questionIndex];
  
  // Генерируем уникальный Callback-data для каждого ответа
  const buttons = q.options.map((option, index) => 
    Markup.button.callback(option, `quiz_${questionIndex}_${index}`)
  );
  
  // Разделяем кнопки: по 1 кнопке на строку для лучшей читаемости длинного текста ответов
  const keyboard = buttons.map(btn => [btn]);
  
  // Определяем категорию для красивого визуала
  let category = '🌐 HTML';
  if (questionIndex >= 20 && questionIndex < 40) category = '🎨 CSS';
  if (questionIndex >= 40) category = '⚡ JavaScript';

  await ctx.reply(
    `🔹 *Категория:* ${category}\n` +
    `📝 *Вопрос:* ${questionIndex + 1}/${quizQuestions.length}\n\n` +
    `*${q.question}*`,
    {
      parse_mode: 'Markdown',
      ...Markup.inlineKeyboard(keyboard)
    }
  );
}

