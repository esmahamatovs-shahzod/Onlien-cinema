// Обработка кликов по вариантам ответов
bot.action(/quiz_(\d+)_(\d+)/, async (ctx) => {
  const chatId = ctx.chat.id;
  const questionIndex = parseInt(ctx.match[1]);
  const selectedOption = parseInt(ctx.match[2]);
  
  // Защита: инициализируем сессию, если её нет
  if (!userSessions.has(chatId)) {
    userSessions.set(chatId, { score: 0, currentQuestion: 0 });
  }
  
  const session = userSessions.get(chatId);
  
  // Защита от повторного нажатия на старые кнопки
  if (questionIndex !== session.currentQuestion) {
    await ctx.answerCbQuery('⚠️ Этот вопрос уже неактивен.');
    return;
  }
  
  const question = quizQuestions[questionIndex];
  const isCorrect = selectedOption === question.correct;
  
  if (isCorrect) {
    session.score += 1;
  }
  
  // Удаляем сообщение с вопросом, чтобы не засорять чат
  await ctx.deleteMessage().catch(() => {});
  
  // Красивый фидбек в чат
  const feedback = isCorrect 
    ? `✅ *Правильно!*\n↳ _${question.options[question.correct]}_` 
    : `❌ *Неверно!*\n↳ Правильный ответ: *${question.options[question.correct]}*`;
  
  await ctx.reply(feedback, { parse_mode: 'Markdown' });
  
  // Переходим к следующему вопросу
  session.currentQuestion += 1;
  
  // Проверяем окончание викторины
  if (session.currentQuestion >= quizQuestions.length) {
    const finalScore = session.score;
    const percentage = Math.round((finalScore / quizQuestions.length) * 100);
    
    let grade = '';
    if (percentage >= 90) grade = '🏆 *Феноменально! Вы настоящий Fullstack Senior!*';
    else if (percentage >= 70) grade = '🌟 *Отличный результат! Уровень Middle разработчика!*';
    else if (percentage >= 50) grade = '👍 *Хорошо! Базовые знания Junior на месте!*';
    else grade = '📚 *Нужно подтянуть теорию! Почитайте MDN Web Docs.*';
    
    const resultMessage = `🎉 *Викторина полностью завершена!* 🎉\n\n` +
      `📊 Ваш итоговый результат: *${finalScore} из ${quizQuestions.length}*\n` +
      `📈 Процент правильных ответов: *${percentage}%*\n\n` +
      `${grade}\n\n` +
      `Вы можете начать заново, нажав кнопку ниже!`;
    
    await ctx.reply(resultMessage, { parse_mode: 'Markdown', ...getMainMenuKeyboard() });
    userSessions.delete(chatId); // Удаляем сессию после финиша
  } else {
    // Отправляем следующий вопрос
    await sendQuestion(ctx, session.currentQuestion);
  }
  
  await ctx.answerCbQuery();
});

// Обработка текстовых команд меню
bot.on('text', async (ctx) => {
  const chatId = ctx.chat.id;
  const text = ctx.message.text;
  
  if (text === '🚀 Начать викторину') {
    userSessions.set(chatId, { score: 0, currentQuestion: 0 });
    await ctx.reply('🏁 Викторина началась! Удачи!');
    await sendQuestion(ctx, 0);
  } 
  else if (text === '📊 Мой счет') {
    if (userSessions.has(chatId)) {
      const session = userSessions.get(chatId);
      await ctx.reply(`📊 *Ваш текущий прогресс:*\nПравильных ответов: *${session.score}*\nПройдено вопросов: *${session.currentQuestion}/${quizQuestions.length}*`, { parse_mode: 'Markdown' });
    } else {
      await ctx.reply('📊 Вы еще не начали викторину. Нажмите *🚀 Начать викторину*.', { parse_mode: 'Markdown' });
    }
  } 
  else if (text === '🔄 Сбросить прогресс') {
    userSessions.delete(chatId);
    await ctx.reply('🔄 Прогресс успешно сброшен. Вы можете начать тест заново!', getMainMenuKeyboard());
  }
  else if (text !== '/start' && text !== '/help') {
    await ctx.reply('🧩 Пожалуйста, используйте кнопки меню для управления викториной!', getMainMenuKeyboard());
  }
});

