// KARTA ORQALI TO'LOV TIZIMI (INVOICE)
bot.action(/buy_(.+)/, async (ctx) => {
  const prodId = ctx.match[1];
  let prod = db.products.find(p => p.id === prodId) || db.productPool.find(p => p.id === prodId);

  if (!prod) return ctx.answerCbQuery('Mahsulot topilmadi.');
  await ctx.answerCbQuery();

  try {
    await ctx.replyWithInvoice({
      provider_token: PROVIDER_TOKEN,
      start_parameter: 'shop_payment',
      title: prod.title,
      description: prod.description,
      currency: 'UZS',
      prices: [{ label: prod.title, amount: prod.price * 100 }], 
      payload: prod.id,
      photo_url: prod.image, 
      photo_width: 600,
      photo_height: 400
    });
  } catch (error) {
    console.error("To'lov xatoligi:", error);
    await ctx.reply("❌ To'lov tizimini yuklashda xatolik yuz berdi.");
  }
});

bot.on('pre_checkout_query', (ctx) => ctx.answerPreCheckoutQuery(true));

bot.on('successful_payment', async (ctx) => {
  const user = initUser(ctx.from.id, ctx.from.first_name);
  const prodId = ctx.message.successful_payment.invoice_payload;
  let prod = db.products.find(p => p.id === prodId) || db.productPool.find(p => p.id === prodId);

  if (prod) {
    user.purchases.push(prod.title);
    await ctx.reply(`🎉 <b>Xarid muvaffaqiyatli yakunlandi!</b>\n\nSiz <b>${prod.title}</b> mahsulotini karta orqali muvaffaqiyatli sotib oldingiz!`, { parse_mode: 'HTML' });
  }
});

