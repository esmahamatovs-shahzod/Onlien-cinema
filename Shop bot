// ⏰ TAYMER 2: YANGI MAHSULOT QO'SHILISHI (4 MINUT, MAX 20)
// ==========================================
setInterval(async () => {
  if (db.products.length >= 20 || db.productPool.length === 0 || db.users.size === 0) return;

  const newProduct = db.productPool.shift(); 
  db.products.push(newProduct);

  for (const userId of db.users.keys()) {
    try {
      const buyKeyboard = Markup.inlineKeyboard([
        [Markup.button.callback(`💳 Sotib olish - ${newProduct.price.toLocaleString()} UZS`, `buy_${newProduct.id}`)]
      ]);

      await bot.telegram.sendPhoto(userId, newProduct.image, {
        caption: `🛍 <b>Do'konga yangi eksklyuziv mahsulot qo'shildi!</b>\n\n📦 <b>${newProduct.title}</b>\n\n📝 ${newProduct.description}\n\n💰 <b>Narxi:</b> ${newProduct.price.toLocaleString()} UZS\n\n<i>Vitrinadagi jami tovarlar: ${db.products.length}/20 ta.</i>`,
        parse_mode: 'HTML',
        ...buyKeyboard
      });
    } catch (err) {
      if (err.description && err.description.includes('forbidden')) db.users.delete(userId);
    }
  }
}, 4 * 60 * 1000); 

