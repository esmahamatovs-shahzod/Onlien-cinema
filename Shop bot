function initUser(id, firstName) {
  if (!db.users.has(id)) {
    db.users.set(id, {
      telegramId: id,
      fullName: firstName,
      favorites: [],
      purchases: [],
      createdAt: new Date().toLocaleDateString()
    });
  }
  return db.users.get(id);
}

