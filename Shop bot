setInterval(async () => {
  if (db.users.size === 0 || db.articles.length === 0) return;

  currentGlobalNewsIndex = (currentGlobalNewsIndex + 1) % db.articles.length;
  const currentNews = db.articles[currentGlobalNewsIndex];

  for (const userId of db.users.keys()) {
    try {
      await bot.telegram.sendPhoto(userId, currentNews.image, { 
        caption: `🔔 <b>Yangi maqola! (Har 4 daqiqada):</b>\n\n<b>${currentNews.title}</b>\n\n${currentNews.content}`,
        parse_mode: 'HTML',
        ...getNewsInlineKeyboard(currentNews._id)
      });
    } catch (err) {
      if (err.description && err.description.includes('forbidden')) db.users.delete(userId); 
    }
  }
}, 4 * 60 * 1000); 

