// Store user sessions
const userSessions = new Map();

// Main menu keyboard
function getMainMenuKeyboard() {
  return Markup.keyboard([
    ['🚗 Начать викторину'],
    ['📊 Мой счет', '🔄 Перезапустить']
  ]).resize();
}

// Function to send question with options
async function sendQuestion(ctx, questionIndex) {
  const q = quizQuestions[questionIndex];
  const buttons = q.options.map((option, index) => 
    Markup.button.callback(option, `answer_${questionIndex}_${index}`)
  );
  
  // Split buttons into rows of 2
  const keyboard = [];
  for (let i = 0; i < buttons.length; i += 2) {
    keyboard.push(buttons.slice(i, i + 2));
  }
  
  await ctx.reply(
    `📝 Вопрос ${questionIndex + 1}/${quizQuestions.length}\n\n${q.question}`,
    Markup.inlineKeyboard(keyboard)
  );
}

// Start command
bot.start(async (ctx) => {
  const welcomeMessage = `🚗 Добро пожаловать в викторину о BMW! 🚗\n\n` +
    `Проверьте свои знания об автомобилях и истории BMW.\n` +
    `Всего ${quizQuestions.length} вопросов.\n\n` +
    `Нажмите "Начать викторину" чтобы начать!`;
  
  await ctx.reply(welcomeMessage, getMainMenuKeyboard());
});

// Help command
bot.help(async (ctx) => {
