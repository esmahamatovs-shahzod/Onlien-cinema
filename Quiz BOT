    'Всего 20 вопросов. Удачи!'
  );
});

// Handle callback queries (button clicks)
bot.action(/answer_(\d+)_(\d+)/, async (ctx) => {
  const chatId = ctx.chat.id;
  const data = ctx.match;
  const questionIndex = parseInt(data[1]);
  const selectedOption = parseInt(data[2]);
  
  // Get or create session
  if (!userSessions.has(chatId)) {
    userSessions.set(chatId, { score: 0, currentQuestion: 0 });
  }
  
  const session = userSessions.get(chatId);
  const question = quizQuestions[questionIndex];
  const isCorrect = selectedOption === question.correct;
  
  // Update score
  if (isCorrect) {
    session.score += 1;
  }
  
  // Delete the question message
  await ctx.deleteMessage().catch(() => {});
  
  // Send feedback
  const feedback = isCorrect ? '✅ Правильно!' : `❌ Неправильно! Правильный ответ: ${question.options[question.correct]}`;
  await ctx.reply(feedback);
  
  // Move to next question
  session.currentQuestion += 1;
  
  // Check if quiz is complete
  if (session.currentQuestion >= quizQuestions.length) {
    const finalScore = session.score;
    const percentage = Math.round((finalScore / quizQuestions.length) * 100);
    
    let grade = '';
    if (percentage >= 90) grade = '🏆 Отлично! Вы эксперт по BMW!';
    else if (percentage >= 70) grade = '🌟 Хорошая работа! Вы хорошо знаете BMW!';
    else if (percentage >= 50) grade = '👍 Неплохо! Продолжайте изучать BMW!';
    else grade = '📚 Вам нужно больше узнать о BMW!';
    
    const resultMessage = `🎉 Викторина завершена! 🎉\n\n` +
      `Ваш счет: ${finalScore}/${quizQuestions.length}\n` +
      `Процент: ${percentage}%\n\n` +
      `${grade}\n\n` +
      `Нажмите "Начать викторину" чтобы сыграть снова!`;
    
    await ctx.reply(resultMessage, getMainMenuKeyboard());
    userSessions.delete(chatId);
  } else {
    // Send next question
    await sendQuestion(ctx, session.currentQuestion);
  }
  
  await ctx.answerCbQuery();
});

// Handle text messages
bot.on('text', async (ctx) => {
  const chatId = ctx.chat.id;
  const text = ctx.message.text;
  
  if (text === '🚗 Начать викторину') {
    // Reset session and start quiz
    userSessions.set(chatId, { score: 0, currentQuestion: 0 });
    await sendQuestion(ctx, 0);
  } 
  else if (text === '📊 Мой счет') {
    if (userSessions.has(chatId)) {
      const session = userSessions.get(chatId);
      await ctx.reply(`📊 Ваш текущий счет: ${session.score}/${session.currentQuestion}`);
    } else {
      await ctx.reply('📊 Вы еще не начали викторину! Нажмите "Начать викторину".');
    }
  } 
  else if (text === '🔄 Перезапустить') {
    userSessions.delete(chatId);
    await ctx.reply('🔄 Викторина перезапущена! Нажмите "Начать викторину" чтобы начать заново.', getMainMenuKeyboard());
  }
  else if (text !== '/start' && text !== '/help') {
    await ctx.reply('🚗 Используйте кнопки ниже для навигации!', getMainMenuKeyboard());
  }
});

// Error handling
bot.catch((err, ctx) => {
  console.error('Error:', err);
  ctx.reply('Произошла ошибка. Пожалуйста, попробуйте снова.');
});

// Launch bot
bot.launch().then(() => {
  console.log('🚗 Бот викторины о BMW запущен!');
});

// Enable graceful stop
process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));


